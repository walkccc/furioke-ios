{
  "singleQuote": true,
  "tabWidth": 2,
  "semi": true,
  "trailingComma": "all",
  "printWidth": 80,
  "overrides": [
    {
      "files": ["*.md", "**/*.md"],
      "options": {
        "proseWrap": "always",
        "printWidth": 80,
        "embeddedLanguageFormatting": "auto"
      }
    }
  ]
}
