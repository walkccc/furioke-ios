      }
    },
    "The whole app is free. Plus lifts the limits when you want more." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アプリはすべて無料。もっと使いたいときに Plus が制限を解放します。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "整個 app 都是免費的。需要更多功能時，Plus 為你解除限制。" } }
      }
    },
    "Unlimited AI translations and flashcards." : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "AI翻訳と単語カードが無制限。" } },
